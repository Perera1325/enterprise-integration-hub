<?xml version="1.0" encoding="UTF-8"?>
<endpoint name="PaymentEndpoint" xmlns="http://ws.apache.org/ns/synapse">
    <http method="post" uri-template="https://api.payment.enterprise.com/v1/charge">
        <suspendOnFailure>
            <errorCodes>101503,101504,101505,101507,101508</errorCodes>
            <initialDuration>10000</initialDuration>
            <progressionFactor>1.0</progressionFactor>
            <maximumDuration>60000</maximumDuration>
        </suspendOnFailure>
        <timeout>
            <duration>15000</duration>
            <responseAction>fault</responseAction>
        </timeout>
    </http>
</endpoint>
